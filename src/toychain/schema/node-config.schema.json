{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toychain.local/schema/node-config.schema.json",
  "title": "Toychain node config",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "data_dir", "port"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "data_dir": {
      "type": "string",
      "minLength": 1
    },
    "port": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    }
  }
}
