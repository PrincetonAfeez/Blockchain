{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toychain.local/schema/transaction.schema.json",
  "title": "Toychain transaction",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "sender",
    "recipient",
    "amount",
    "nonce",
    "public_key",
    "signature"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "sender": {
      "type": "string"
    },
    "recipient": {
      "type": "string"
    },
    "amount": {
      "type": "integer"
    },
    "nonce": {
      "type": "integer"
    },
    "public_key": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{16}$|^[0-9a-f]{64}$"
    },
    "signature": {
      "type": "string",
      "pattern": "^$|^[0-9a-f]{128}$"
    }
  }
}
