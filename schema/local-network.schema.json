{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toychain.local/schema/local-network.schema.json",
  "title": "Toychain local network registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["nodes"],
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "port"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^node[1-9][0-9]*$"
          },
          "port": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
