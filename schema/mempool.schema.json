{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toychain.local/schema/mempool.schema.json",
  "title": "Toychain mempool storage",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "transactions"],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "transactions": {
      "type": "array",
      "items": {
        "$ref": "transaction.schema.json"
      }
    }
  }
}
