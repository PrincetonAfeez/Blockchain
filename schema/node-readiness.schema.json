{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://toychain.local/schema/node-readiness.schema.json",
  "title": "Toychain node readiness record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "instance_id",
    "pid",
    "data_dir",
    "port",
    "ready_at"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "instance_id": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[1-5][0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "pid": {
      "type": "integer",
      "minimum": 1
    },
    "data_dir": {
      "type": "string",
      "minLength": 1
    },
    "port": {
      "type": "integer",
      "minimum": 0,
      "maximum": 65535
    },
    "ready_at": {
      "type": "integer",
      "minimum": 0
    }
  }
}
